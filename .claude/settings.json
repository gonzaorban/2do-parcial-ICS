{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run format)",
      "Bash(npm run format:*)",
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run e2e)",
      "Bash(npm run e2e:*)",
      "Bash(npx playwright install:*)",
      "Bash(npx playwright test:*)",
      "Bash(npx playwright --version)",
      "Bash(npx next:*)",
      "Bash(bash setup.sh)",
      "Bash(bash setup.sh:*)",
      "Bash(docker compose up)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down)",
      "Bash(docker compose build)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs)",
      "Bash(docker compose logs:*)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git init)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git show:*)",
      "Bash(curl http://localhost:3000)",
      "Bash(curl http://localhost:3000/*)",
      "Bash(curl -fs http://localhost:3000)",
      "Bash(curl -fs http://localhost:3000/*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git remote add:*)",
      "Bash(git remote set-url:*)",
      "Bash(rm -rf:*)",
      "Bash(npm publish:*)"
    ]
  },
  "env": {
    "NODE_OPTIONS": "--no-warnings"
  }
}
